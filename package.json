{
  "name": "collectiq-backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "migration:run": "node ./node_modules/typeorm/cli-ts-node-commonjs.js migration:run -d src/database/collectiq-typeorm.datasource.ts",
    "migration:revert": "node ./node_modules/typeorm/cli-ts-node-commonjs.js migration:revert -d src/database/collectiq-typeorm.datasource.ts",
    "migration:show": "node ./node_modules/typeorm/cli-ts-node-commonjs.js migration:show -d src/database/collectiq-typeorm.datasource.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0",
    "pdfkit": "^0.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "stripe": "^17.5.0",
    "twilio": "^5.4.5",
    "typeorm": "^0.3.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.12",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.13.9",
    "@types/supertest": "^6.0.2",
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.2"
  }
}
