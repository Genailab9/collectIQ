{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run lint:eslint && npm run lint:governance:contracts && npm run lint:governance:domain && npm run lint:governance:execution",
    "lint:eslint": "eslint",
    "lint:governance:contracts": "node scripts/check-bff-prefix-lock.mjs && node scripts/check-client-api-surface.mjs && node scripts/check-bff-contract-manifest.mjs && node scripts/check-no-secret-fallbacks.mjs",
    "lint:governance:domain": "node scripts/check-polling-policy.mjs && node scripts/check-api-client-usage.mjs && node scripts/check-domain-isolation.mjs",
    "lint:governance:execution": "node scripts/check-execution-projection-governance.mjs && node scripts/check-execution-purity-governance.mjs && node scripts/check-execution-slos-contract.mjs && node scripts/check-execution-schema-governance.mjs",
    "test": "node --test tests/**/*.test.mjs",
    "test:e2e:tenant-context": "node scripts/run-tenant-context-e2e.mjs",
    "test:e2e:tenant-context:race": "node scripts/run-tenant-context-race-e2e.mjs",
    "test:e2e:tenant-sse-switch-isolation": "node scripts/run-tenant-sse-switch-isolation-e2e.mjs",
    "test:e2e:distributed-tenant-isolation": "node scripts/run-distributed-tenant-isolation-cert.mjs",
    "env:auto": "node scripts/auto-config.mjs",
    "governance:summary": "node ../backend/scripts/generate-governance-summary.mjs",
    "allowlist:plan": "node ../backend/scripts/generate-allowlist-execution-artifacts.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
